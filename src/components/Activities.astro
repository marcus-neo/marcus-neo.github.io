---
const activities = [
  {
    icon: "🤿",
    title: "Scuba Diving",
    description: "PADI Advanced Open Water · Nitrox · Drysuit · 50+ Logged Dives",
    detail: "Bali, Indonesia · Ko Tao, Thailand · Malapascua, Philippines · Osezaki, Japan · Tioman, Malaysia",
  },
  {
    icon: "🏂",
    title: "Snowboarding",
    description: "Picking it up one run at a time",
    detail: "Norikura Kogen, Japan · Yabuli, China",
  },
  {
    icon: "🃏",
    title: "Contract Bridge",
    description: "Serious hobbyist — always looking for a table",
    detail: "2/1 GF · 15-17 NT · Jacoby 2NT · Bergen Raises · RKCB 1430",
    link: { href: "/bridge_reference.pdf", label: "Want to learn? Try this!" },
  },
];
---

<section id="activities" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="reveal flex items-baseline gap-3 mb-12">
      <span class="font-mono text-sm text-zinc-400 dark:text-zinc-600 tracking-widest select-none">05</span>
      <h2 class="font-display text-2xl font-bold text-zinc-900 dark:text-zinc-50">Activities & Interests</h2>
    </div>

    <div class="reveal-children grid gap-6 sm:grid-cols-3">
      {activities.map((activity) => (
        <div class="p-5 rounded-xl border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900/50 flex flex-col">
          <span class="text-2xl mb-3 block">{activity.icon}</span>
          <h3 class="font-display font-semibold text-zinc-900 dark:text-zinc-100 mb-2">{activity.title}</h3>
          <p class="text-sm text-zinc-600 dark:text-zinc-400">{activity.description}</p>
          {activity.detail && <p class="font-mono text-xs text-zinc-500 dark:text-zinc-500 mt-auto pt-3">{activity.detail}</p>}
          {activity.link && (
            <a href={activity.link.href} target="_blank" rel="noopener noreferrer" class="inline-block mt-3 text-xs text-accent hover:underline">
              {activity.link.label} →
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
