---
const skillGroups = [
  {
    label: "Languages",
    skills: ["Python", "C++"],
  },
  {
    label: "ML Frameworks",
    skills: ["PyTorch", "TensorFlow", "JAX", "ONNX", "MONAI", "Ultralytics"],
  },
  {
    label: "Serving & Export",
    skills: ["Triton Inference Server", "TensorRT", "CoreML", "TFLite", "OpenVINO", "Numba"],
  },
  {
    label: "VLM Fine-Tuning",
    skills: ["LoRA", "Quantization", "Tensor Parallelism", "DeepSpeed", "HuggingFace"],
  },
  {
    label: "Cloud & Infrastructure",
    skills: ["GCP", "Compute Engine", "Cloud Run", "GKE", "PubSub", "Docker", "Kubernetes", "KEDA", "CUDA"],
  },
];
---

<section id="skills" class="py-20 px-6 bg-zinc-50 dark:bg-zinc-900/30">
  <div class="max-w-5xl mx-auto">
    <div class="reveal flex items-baseline gap-3 mb-12">
      <span class="font-mono text-xs text-zinc-400 dark:text-zinc-600 tracking-widest select-none">02</span>
      <h2 class="font-display text-2xl font-bold text-zinc-900 dark:text-zinc-50">Skills</h2>
    </div>

    <div class="reveal-children space-y-8">
      {skillGroups.map((group) => (
        <div>
          <h3 class="font-mono text-[10px] font-medium text-zinc-500 dark:text-zinc-500 uppercase tracking-[0.2em] mb-3">
            {group.label}
          </h3>
          <div class="flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <span class="font-mono px-3 py-1.5 text-xs font-medium rounded-lg bg-white dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 text-zinc-700 dark:text-zinc-300">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
